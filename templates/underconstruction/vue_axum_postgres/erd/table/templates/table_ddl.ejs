<%_
  // BIGINT の主キーを BIGSERIAL として書き直す。
  // TODO: これはERD自体の修正でも対応できるだろう。
  function fixBigintIdColumn(column) {
    if (column.pname === 'id' && column.type === 'BIGINT') {
      return {
        ...column,
        type: 'BIGSERIAL',
        default: undefined,
      }
    }

    return column
  }

  // スキーマをテーブルに読み込む。
  function loadTableSchemas(table) {
    const { garbage } = table.metadata ?? {}

    if (garbage === false) {
      table.schemas = ['public']

    } else {
      table.schemas = ['public', 'garbage']
    }
  }

  // インデクスをテーブルに読み込む。
  function loadTableIndexes(table) {
    const { unique, indexes } = table.metadata ?? {}
    table.unique = unique || []
    table.indexes = indexes || []
  }

  // partitionをテーブルに読み込む。
  function loadTablePartitions(table) {
    const { partitions } = table.metadata ?? {}

    if (partitions) {
      table.partitions = partitions.map(partition => {
        const { column } = partition

        return {
          type: column.endsWith('_uuid') || column.endsWith('_id')
            ? 'LIST'
            : 'RANGE',
          column,
        }
      })

    } else {
      table.partitions = []
    }
  }

  // 追加情報を読み込んでテーブルに付ける。
  function loadTable(table) {
    loadTableIndexes(table)
    loadTableSchemas(table)
    loadTablePartitions(table)
  }

  table = _
    .chain(table)
    .tap(loadTable)
    .value()

  const columns = _
    .chain(table.columns)
    .map(fixBigintIdColumn)
    .value()

  const fks = (table.fks ? table.fks : []).map((fk) => {
    let columns = fk.columns.map((column) => column.pname).join(', ');
    let foreignColumns = fk.foreignColumns.map((column) => column.pname).join(', ');
    let res = `\n  ,FOREIGN KEY (${columns}) REFERENCES ${fk.table.pname}(${foreignColumns})`;
    return res;
  }).join('')
_%>
<%_
  table.schemas.forEach(schema => {

    // partitionがある場合、publicのみに付ける。
    const isPartitioned = schema === 'public' && table.partitions.length > 0
_%>
DROP TABLE IF EXISTS <%= schema %>.<%= table.pname %> CASCADE;
CREATE TABLE <%= schema %>.<%= table.pname %> (
<%_ columns.forEach((column, index) => { _%>
  <%= index !== 0 ? ',' : '' _%>
<%= column.pname _%>
<%- ` ${column.type}` _%>
<%= column.notNull ? ' NOT NULL' : '' _%>
<%- column.default && column.notNull ? ` DEFAULT ${column.default}` : '' _%>
<%- ` -- ${column.lname}` %>
<%_ }) _%>
  ,created_uuid UUID
  ,updated_uuid UUID
  ,deleted_uuid UUID
  ,created_at TIMESTAMPTZ NOT NULL DEFAULT now()
  ,updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
  ,deleted_at TIMESTAMPTZ
  ,created_pg TEXT NOT NULL DEFAULT ''
  ,updated_pg TEXT NOT NULL DEFAULT ''
  ,deleted_pg TEXT NOT NULL DEFAULT ''
  ,bk TEXT
<%_ if (!isPartitioned) { _%>
  ,PRIMARY KEY(<%=
    _.chain(columns)
      .filter(column => column.pk)
      .map(column => column.pname)
      .join(', ')
      .value()
  %>)
<%_ } _%>
<%_ if (schema === 'public' && !!fks) {
_%><%= fks %>
<%_ } _%>
<%- ')' _%>
<%_
  if (isPartitioned) {
    const partition = table.partitions[0]
_%>
 PARTITION BY <%= partition.type %> (<%= partition.column _%>)<%_ _%>
<%_ } _%>;

<%_
  let indexes = table.indexes || []
_%>
<%_ for (const keys of indexes) { _%>
CREATE INDEX idx_<%= table.pname %>_<%= keys.join('_') %> ON <%= schema %>.<%= table.pname %>(<%= keys.join(',') %>);
<%_ } _%>
<%_
  let unique = []

  if (schema === 'garbage') {
    unique = table.unique || []
  }
_%>
<%_ for (const keys of unique) { _%>
<%#_ NOTE: unique 制約を入れる場合、 garbage には index 制約を入れるのが正しい。 _%>
<%#_       public は partition で分割されているため、異なる企業に同じ名前を持つデータがあるかもしれない _%>
CREATE INDEX idx_<%= table.pname %>_<%= keys.join('_') %> ON <%= schema %>.<%= table.pname %>(<%= keys.join(',') %>);
<%_ } _%>
<%_ }) _%>
