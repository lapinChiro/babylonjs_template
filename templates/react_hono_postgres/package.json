{
  "name": "app",
  "private": true,
  "workspaces": [
    "packages/client",
    "packages/server"
  ],
  "scripts": {
    "typecheck": "bun run --filter '@app/*' typecheck",
    "typecheck:client": "bun run --filter @app/client typecheck",
    "typecheck:server": "bun run --filter @app/server typecheck",
    "dev": "bun run --filter '@app/*' dev",
    "dev:client": "bun run --filter @app/client dev",
    "dev:server": "bun run --filter @app/server dev",
    "db:generate": "bun run --filter @app/server db:generate",
    "db:migrate": "bun run --filter @app/server db:migrate",
    "clean": "rm -rf node_modules packages/client/node_modules packages/server/node_modules bun.lock packages/client/bun.lock packages/server/bun.lock"
  }
}