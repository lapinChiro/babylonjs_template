# Application
HOST=localhost:3000
BASE_PATH=

# Database (automatically configured in Docker)
# DATABASE_URL is set by compose.yaml

# MinIO Configuration (automatically configured in Docker)
# These are set in compose.yaml and used by the backend
MINIO_ENDPOINT=minio
MINIO_EXTERNAL_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=item-images
MINIO_UPLOAD_URL_EXPIRY=600

# Frontend URLs (automatically configured in Docker)
VITE_SERVER_URL=http://localhost:3000/api
VITE_BETTER_AUTH_URL=http://localhost:3000/api/auth

# Backend URLs (automatically configured in Docker)
BETTER_AUTH_URL=http://localhost:3000/api/auth
CORS_ORIGIN=http://localhost:5173
