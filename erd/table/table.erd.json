{
  "meta": {
    "version": "1.0.0"
  },
  "includes": [
    "_domain.erd.json"
  ],
  "templates": {
    "table": [
      {
        "template": "erd/table/templates/table_ddl.ejs",
        "file": "db/sql/table/${index}_${pname}.sql",
        "refresh": true
      },
      {
        "template": "erd/table/templates/table_rs.ejs",
        "file": "apps/services/crates/postgresql/src/table/${pname}.rs",
        "refresh": true
      },
      {
        "template": "erd/table/templates/stored_sql_set_add.ejs",
        "file": "db/sql/stored/generated/generated_set_add_${pname}.sql",
        "refresh": true
      },
      {
        "template": "erd/table/templates/stored_sql_get_list.ejs",
        "file": "db/sql/stored/generated/generated_get_list_${pname}.sql",
        "refresh": true
      },
      {
        "template": "erd/table/templates/stored_sql_set_delete.ejs",
        "file": "db/sql/stored/generated/generated_set_delete_${pname}.sql",
        "refresh": true
      }
    ]
  },
  "tables": [
    {
      "lname": "ユーザー",
      "pname": "users",
      "columns": [
        {
          "domain": "UUID",
          "pk": true,
          "default": "uv_uuid_v7()"
        },
        {
          "lname": "ユーザー",
          "pname": "user",
          "domain": "コード"
        },
        {
          "lname": "名前",
          "pname": "name",
          "domain": "名前",
          "overrideDomainName": true
        },
        {
          "domain": "メール"
        },
        {
          "lname": "最終ログイン",
          "pname": "last_login",
          "domain": "日時"
        }
      ]
    },
    {
      "lname": "セッション",
      "pname": "sessions",
      "fks": [
        {
          "columns": ["ユーザーUUID"],
          "table": "ユーザー",
          "foreignColumns": ["UUID"]
        }
      ],
      "columns": [
        {
          "domain": "UUID",
          "pk": true,
          "default": "uv_uuid_v7()"
        },
        {
          "lname": "ユーザー",
          "pname": "user",
          "domain": "UUID"
        },
        {
          "lname": "破棄",
          "pname": "expire",
          "domain": "日時"
        }
      ]
    },
    {
      "lname": "メモ",
      "pname": "memos",
      "fks": [
        {
          "columns": ["ユーザーUUID"],
          "table": "ユーザー",
          "foreignColumns": ["UUID"]
        }
      ],
      "columns": [
        {
          "domain": "UUID",
          "pk": true,
          "default": "uv_uuid_v7()"
        },
        {
          "lname": "ユーザー",
          "pname": "user",
          "domain": "UUID"
        },
        {
          "domain": "タイトル"
        },
        {
          "domain": "内容"
        },
        {
          "lname": "親メモ",
          "pname": "parent_memo",
          "notNull": false,
          "domain": "UUID"
        }
      ]
    }
  ]
}