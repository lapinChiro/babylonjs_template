<%
  const additionalWhere = (table.metadata || {})["additional_where"] || []
  const additionalReturn = (table.metadata || {})["additional_return"] || []
  const joins = (table.metadata || {})["join"] || []
  
  const types = table.columns.concat(additionalReturn).map((column) => {
    return  (column.type === 'BIGSERIAL') ?  `${column.pname} BIGINT` : `${column.pname} ${column.type}`;
  }).join('\n  ,');
  const parameters = table.columns.concat(additionalWhere).map((column) => {
    return  (column.type === 'BIGSERIAL') ?  `p_${column.pname} BIGINT DEFAULT NULL` : `p_${column.pname} ${column.type} DEFAULT NULL`;
  }).join('\n  ,');
  const selects = table.columns.map((column) => {
    return `t1.${column.pname}`;
  }).concat(additionalReturn.map((column) => {
    return `${column.value}`
  }))
  const wheres = table.columns.map((column) => {
    return `(p_${column.pname} IS NULL OR t1.${column.pname} = p_${column.pname})`;
  }).concat(
    additionalWhere.map((column) => {
      return `(p_${column.pname} IS NULL OR ${column.value})`
    })
  );
  const returns = table.columns.map((column) => {
    let col_text = `${column.pname}`;
    return col_text;
  }).join('\n      ,');
  const commentParameters = table.columns.concat(additionalWhere).map((column) => {
    let col_text = `p_${column.pname} : ${column.lname}`;
    return col_text;
  }).join('\n--   ');
  const commentReturns = table.columns.concat(additionalReturn).map((column) => {
    let col_text = `${column.pname} : ${column.lname}`;
    return col_text;
  }).join('\n--   ');
  let orderBy = `\n  ORDER BY t1.created_at`;
  if (table.metadata && table.metadata['order_by']) {
    const items = table.metadata['order_by']
    orderBy = `\n  ORDER BY\n    ${items.join("\n    , ")} `;
  }
  const froms = [`public.${table.pname} AS t1`].concat(
    joins.map((join) => {
      let joinPrefix = '';
      if (join.type == 'cross') {
        joinPrefix = 'CROSS JOIN';
      } else if (join.type == 'left') {
        joinPrefix = 'LEFT OUTER JOIN';
      } else if (join.type == 'right') {
        joinPrefix = 'RIGHT OUTER JOIN'
      }
      return `${joinPrefix} ${join.table} AS ${join.alias} ON ${join.condition}`;
    })
  );
%>DROP TYPE IF EXISTS type_generated_get_list_<%= table.pname %> CASCADE;
CREATE TYPE type_generated_get_list_<%= table.pname %> AS (
  <%- types %>
  ,created_uuid UUID
  ,updated_uuid UUID
  ,deleted_uuid UUID
  ,created_at TIMESTAMPTZ
  ,updated_at TIMESTAMPTZ
  ,deleted_at TIMESTAMPTZ
  ,created_pg TEXT
  ,updated_pg TEXT
  ,deleted_pg TEXT
  ,bk TEXT
);

-- <%= table.lname %> 一覧
-- 引数
--   <%- commentParameters %>
-- 戻り値
--   <%- commentReturns %>
--   created_uuid : 登録者UUID
--   updated_uuid : 更新者UUID
--   deleted_uuid : 更新者UUID
--   created_at : 登録日時
--   updated_at : 更新日時
--   deleted_at : 更新日時
--   created_pg : 登録プログラム名
--   updated_pg : 更新プログラム名
--   deleted_pg : 更新プログラム名
--   bk : 備考
-- 例外
--   なし
CREATE OR REPLACE FUNCTION generated_get_list_<%= table.pname %> (
  <%- parameters %>
  ,p_limit BIGINT DEFAULT NULL
  ,p_offset BIGINT DEFAULT 0
  ,p_with_count_flag BOOLEAN DEFAULT FALSE
) RETURNS SETOF type_generated_get_list_<%= table.pname %> AS $FUNCTION$
DECLARE
  w_record type_generated_get_list_<%= table.pname %>;
BEGIN
  IF p_with_count_flag IS TRUE THEN
    SELECT
      <%- selects.join('\n      ,') %>
      ,t1.created_uuid
      ,t1.updated_uuid
      ,t1.deleted_uuid
      ,t1.created_at
      ,t1.updated_at
      ,t1.deleted_at
      ,t1.created_pg
      ,t1.updated_pg
      ,t1.deleted_pg
      ,t1.bk
    INTO
      w_record
    FROM
      <%- froms.join('\n      ') %>
    LIMIT
      1
    ;
    IF NOT FOUND THEN
      RETURN;
    END IF;

    SELECT
      COUNT(*)::TEXT
    INTO
      w_record.bk
    FROM
      <%- froms.join('\n      ') %>
    WHERE
      <%- wheres.join('\n      AND ') %>
    ;
  END IF;

  RETURN QUERY SELECT
    <%- selects.join('\n    ,') %>
    ,t1.created_uuid
    ,t1.updated_uuid
    ,t1.deleted_uuid
    ,t1.created_at
    ,t1.updated_at
    ,t1.deleted_at
    ,t1.created_pg
    ,t1.updated_pg
    ,t1.deleted_pg
    ,t1.bk
  FROM
    <%- froms.join('\n    ') %>
  WHERE
    <%- wheres.join('\n    AND ') %><%- orderBy %>
  LIMIT
    p_limit
  OFFSET
    p_offset
  ;

  IF p_with_count_flag IS TRUE THEN
    RETURN NEXT w_record;
  END IF;
END;
$FUNCTION$ LANGUAGE plpgsql;